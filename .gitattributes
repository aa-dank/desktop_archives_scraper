# Normalize text files and check them out with CRLF on Windows-focused repo.
* text=auto eol=crlf

# Keep Windows scripts in CRLF explicitly.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat common binary assets as binary to avoid accidental normalization.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
