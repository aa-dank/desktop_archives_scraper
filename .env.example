# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=archives
DB_USERNAME=postgres
DB_PASSWORD=change_me

# File server mount visible to this desktop
FILE_SERVER_MOUNT=N:\PPDO\Records

# Worker behavior
LIMIT=
POLL_SECONDS=5.0
POLL_BATCH_SIZE=10
WRITE_BATCH_SIZE=25
COMMIT_INTERVAL_SECONDS=5.0
EXTENSIONS=
MAX_CHARS=
ENABLE_EMBEDDING=true
EMBEDDER=minilm
INCLUDE_FAILURES=false
RANDOMIZE=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=
JSON_LOGS=false

# Optional extractor tuning examples
# OCR_SUBPROCESS_TIMEOUT_S=600
# IMAGE_OCR_SUBPROCESS_TIMEOUT_S=300
# OFFICE_WORKER_TIMEOUT_S=180
