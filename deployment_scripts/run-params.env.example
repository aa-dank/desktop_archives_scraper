# Central runtime parameters for desktop_archives_scraper.
#
# Copy this file to run-params.env on the common share and edit values there.
# Every desktop will sync and use those values on the next orchestrator run.

# Polling and batching behavior.
POLL_SECONDS=5
POLL_BATCH_SIZE=10
WRITE_BATCH_SIZE=25
COMMIT_INTERVAL_SECONDS=5

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional behavior toggles.
RANDOMIZE=true
INCLUDE_FAILURES=true

# Retry/failure behavior.
FAILURE_RETRY_TRESHOLD=3

# Optional log file path (uncomment and set to a user-writable path).
# LOG_FILE=%LOCALAPPDATA%\desktop_archives_scraper\scraper.log

# Optional processing limits (uncomment if needed).
# LIMIT=100
# MAX_CHARS=2000000

# Optional embedding controls (uncomment if needed).
# ENABLE_EMBEDDING=true
# EMBEDDING_DIMENSIONS=384
